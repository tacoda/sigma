{
  "model": "claude-sonnet-4-6",
  "allowedTools": ["read_file", "grep", "glob"],
  "isolate": true,
  "sandbox": {
    "enabled": true,
    "network": false,
    "writable": []
  },
  "eventLog": ".sigma/events.jsonl",
  "permissionMode": "acceptEdits",
  "compactAt": 120000,
  "outputStyle": "concise",
  "plugins": ["telemetry", "codehealth"],
  "pluginConfig": {
    "codehealth": { "checks": ["go test ./...", "go vet ./..."] }
  },
  "hooks": {
    "PreToolUse": ["./scripts/guard.sh"]
  }
}
